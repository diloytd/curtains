			return true;
		}

		e.preventDefault();

		if(_this.attr('href')){

			$.ajax({
				url:_this.attr('href'),
				type: "GET",
				data: {'ajax_get':'Y', 'ajax_get_filter':'Y', 'from_smartseo':'Y'},
				success: function(html){
					// $('#right_block_ajax').html($(html).find('#right_block_ajax').html());
