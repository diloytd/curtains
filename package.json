{
  "name": "curtans",
  "private": true,
  "version": "1.0.0",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "npm run dev -w @curtans/web",
    "build": "npm run build -w @curtans/web",
    "preview": "npm run preview -w @curtans/web",
    "dev:calc3d": "npm run dev -w @curtans/calc3d",
    "build:calc3d": "npm run build -w @curtans/calc3d",
    "preview:calc3d": "npm run preview -w @curtans/calc3d",
    "dev:karniz": "npm run dev -w @curtans/karniz-mirror",
    "build:karniz": "npm run build -w @curtans/karniz-mirror",
    "preview:karniz": "npm run preview -w @curtans/karniz-mirror",
    "dev:karniz2": "npm run dev -w @curtans/karniz-mirror2",
    "build:karniz2": "npm run build -w @curtans/karniz-mirror2",
    "preview:karniz2": "npm run preview -w @curtans/karniz-mirror2",
    "test": "npm run test --workspaces --if-present",
    "test:run": "npm run test:run --workspaces --if-present"
  }
}
