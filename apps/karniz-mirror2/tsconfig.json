{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["vite/client", "node"],
    "paths": {
      "@curtans-web/*": ["../web/src/*"]
    }
  },
  "include": ["src/**/*.tsx", "src/**/*.ts", "vite.config.ts"]
}
